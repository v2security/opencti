# syntax=docker/dockerfile:1
###############################################################################
# OpenCTI Patched Build
#
# Multi-stage: compile patched TypeScript -> back.js, overlay on official image.
# EE bypass patching happens INSIDE the build (source in git stays clean).
#
# Usage:
#   docker compose build opencti          # Build from docker-compose.yml
#   docker build --build-arg OPENCTI_VERSION=6.9.22 \
#     -f Dockerfile.patch -t opencti/platform:6.9.22-patched .
###############################################################################

ARG OPENCTI_VERSION=6.9.22

# ─── Stage 1: Build patched backend ───
FROM node:22-alpine AS backend-builder

RUN corepack enable

WORKDIR /opt/opencti-build/opencti-graphql

# Copy package files first (layer caching: deps don't change often)
COPY opencti-platform/opencti-graphql/package.json \
     opencti-platform/opencti-graphql/yarn.lock \
     opencti-platform/.yarnrc.yml \
     ./
COPY opencti-platform/opencti-graphql/patch ./patch

RUN set -ex; \
    apk add --no-cache git tini gcc g++ make musl-dev cargo python3 python3-dev postfix postfix-pcre \
    && rm -f /usr/lib/python3.11/EXTERNALLY-MANAGED \
    && rm -f /usr/lib/python3.12/EXTERNALLY-MANAGED \
    && npm install -g node-gyp \
    && yarn install

# Copy full source
COPY opencti-platform/opencti-graphql /opt/opencti-build/opencti-graphql

# ── EE Bypass: patch inside container (git source stays clean) ──
RUN <<'APPLY_PATCHES'
set -e

# [1/2] Patch ee.ts - full replacement
cat > src/enterprise-edition/ee.ts << 'PATCHED_EE'
import type { AuthContext } from '../types/user';
import { getEntityFromCache } from '../database/cache';
import type { BasicStoreSettings } from '../types/settings';
import { SYSTEM_USER } from '../utils/access';
import { ENTITY_TYPE_SETTINGS } from '../schema/internalObject';
import { UnsupportedError } from '../config/errors';

export const isEnterpriseEdition = async (context: AuthContext) => {
  return true; // EE BYPASS
};

export const isEnterpriseEditionFromSettings = (settings?: Pick<BasicStoreSettings, 'valid_enterprise_edition'>): boolean => {
  return true; // EE BYPASS
};

export const checkEnterpriseEdition = async (context: AuthContext) => {
  return; // EE BYPASS
};
PATCHED_EE

# [2/2] Patch licensing.ts - sed replacements
sed -i 's|license_validated: false,|license_validated: true,|' src/modules/settings/licensing.ts
sed -i 's|license_valid_cert: false,|license_valid_cert: true,|' src/modules/settings/licensing.ts
sed -i 's|license_expired: true,|license_expired: false,|' src/modules/settings/licensing.ts
sed -i "s|license_type: 'trial',|license_type: 'standard',|" src/modules/settings/licensing.ts
sed -i '/^  return {$/,/^  };$/{
  /license_global: false,/{
    s|license_global: false,|license_global: true,|
  }
}' src/modules/settings/licensing.ts

echo "✅ EE bypass patches applied inside Docker build"
APPLY_PATCHES

RUN yarn build:prod

# ─── Stage 2: Overlay onto official image ───
ARG OPENCTI_VERSION
FROM opencti/platform:${OPENCTI_VERSION}

COPY --from=backend-builder /opt/opencti-build/opencti-graphql/build/back.js /opt/opencti/build/back.js
COPY --from=backend-builder /opt/opencti-build/opencti-graphql/src/enterprise-edition/ /opt/opencti/src/enterprise-edition/
COPY --from=backend-builder /opt/opencti-build/opencti-graphql/src/modules/settings/licensing.ts /opt/opencti/src/modules/settings/licensing.ts
