# ─────────────────────────────────────────────────────────────
# source-maltrail .env — Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# MySQL connection (required)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=

# Maltrail repository URL (optional, default below)
# MALTRAIL_REPO=https://github.com/stamparm/maltrail.git

# Data directory for old/new maltrail clones (optional, default: ../data)
# DATA_DIR=../data

# Git binary path (optional, auto-detected)
# GIT_BIN=/usr/bin/git
