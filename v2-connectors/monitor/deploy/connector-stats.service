[Unit]
Description=OpenCTI Connector Event Statistic (daily)
Wants=network-online.target
After=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/opt/connector/monitor
ExecStart=/opt/connector/monitor/connector-stats

StandardOutput=journal
StandardError=journal
SyslogIdentifier=connector-stats

NoNewPrivileges=yes
ProtectSystem=strict
PrivateTmp=yes
