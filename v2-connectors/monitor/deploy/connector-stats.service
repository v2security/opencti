[Unit]
Description=OpenCTI Connector Event Statistic (daily)
Wants=network-online.target
After=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/opt/tools
ExecStart=/opt/tools/connector-stats
EnvironmentFile=/etc/saids/opencti/.env

StandardOutput=journal
StandardError=journal
SyslogIdentifier=connector-stats

NoNewPrivileges=yes
ProtectSystem=strict
PrivateTmp=yes
