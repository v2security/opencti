###############################################################################
# /etc/saids/opencti/.env — Config tập trung cho tất cả components
#
# Platform, Worker, Tools đều đọc từ file này.
# Dev/test: export OPENCTI_ENV_FILE=/workspace/tunv_opencti/.env
###############################################################################

# ── Application ──────────────────────────────────────────────
APP_PORT=8080
APP_BASE_URL=http://localhost:8080
APP_ADMIN_EMAIL=admin@v2secure.vn
APP_ADMIN_PASSWORD=changeme
APP_ADMIN_TOKEN=changeme-uuid
APP_HEALTH_ACCESS_KEY=changeme-uuid
APP_HTTPS_CERT_REJECT_UNAUTHORIZED=false

# ── Redis ────────────────────────────────────────────────────
REDIS_HOSTNAME=localhost
REDIS_PORT=6379
REDIS_PASSWORD=changeme

# ── Elasticsearch ────────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:8686
ELASTICSEARCH_NUMBER_OF_REPLICAS=0
ELASTIC_MEMORY_SIZE=4G

# ── MinIO (S3) ───────────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=opencti
MINIO_SECRET_KEY=changeme
MINIO_BUCKET_NAME=opencti-bucket

# ── RabbitMQ ─────────────────────────────────────────────────
RABBITMQ_HOSTNAME=localhost
RABBITMQ_PORT=5672
RABBITMQ_PORT_MANAGEMENT=15672
RABBITMQ_MANAGEMENT_SSL=false
RABBITMQ_USERNAME=opencti
RABBITMQ_PASSWORD=changeme

# ── SMTP ─────────────────────────────────────────────────────
SMTP_HOSTNAME=localhost
SMTP_PORT=25

# ── AI / Chatbot ─────────────────────────────────────────────
AI_ENABLED=false
AI_TYPE=anthropic
AI_ENDPOINT=
AI_TOKEN=
AI_MODEL=claude-sonnet-4-5-20250929
AI_MODEL_IMAGES=
AI_MAX_TOKENS=30000
AI_TIMEOUT=60000
CHATBOT_API_KEY=
CHATBOT_MODEL=claude-sonnet-4-5-20250929
CHATBOT_MAX_TOKENS=4096

# ── Worker ───────────────────────────────────────────────────
WORKER_LOG_LEVEL=info
WORKER_TELEMETRY_ENABLED=false
WORKER_LISTEN_POOL_SIZE=5
OPENCTI_EXECUTION_POOL_SIZE=2
OPENCTI_REALTIME_EXECUTION_POOL_SIZE=3

# ── MySQL (tools) ────────────────────────────────────────────
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=changeme
MYSQL_DATABASE=ids

# ── Maltrail Sync ────────────────────────────────────────────
# MALTRAIL_REPO=https://github.com/stamparm/maltrail.git
TOOL_DATA_DIR=/opt/tools/data
# GIT_BIN=/usr/bin/git

# ── VirusTotal (hashlist sync) ───────────────────────────────
VIRUSTOTAL_API_KEY=

# ── Docker Compose ───────────────────────────────────────────
OPENCTI_VERSION=6.9.22
XTM_COMPOSER_ID=changeme-uuid
COMPOSE_PROJECT_NAME=opencti-compose

# ── Connectors ───────────────────────────────────────────────
CONNECTOR_OPENCTI_ID=changeme-uuid
CONNECTOR_MITRE_ID=changeme-uuid
CONNECTOR_HISTORY_ID=changeme-uuid
CONNECTOR_EXPORT_FILE_STIX_ID=changeme-uuid
CONNECTOR_EXPORT_FILE_CSV_ID=changeme-uuid
CONNECTOR_EXPORT_FILE_TXT_ID=changeme-uuid
CONNECTOR_IMPORT_FILE_STIX_ID=changeme-uuid
CONNECTOR_IMPORT_DOCUMENT_ID=changeme-uuid
CONNECTOR_ANALYSIS_ID=changeme-uuid
CONNECTOR_IMPORT_FILE_YARA_ID=changeme-uuid
CONNECTOR_IMPORT_EXTERNAL_REFERENCE_ID=changeme-uuid
CONNECTOR_MALTRAIL_ID=changeme-uuid

# OTX Alienvault
CONNECTOR_OTX_ID=changeme-uuid
OTX_API_KEY=

# NVD NIST
CONNECTOR_CVE_ID=changeme-uuid
CONNECTOR_CPE_ID=changeme-uuid
NVD_API_KEY=

# SHODAN
CONNECTOR_SHODAN_ID=changeme-uuid
SHODAN_API_KEY=

# SOCRadar
CONNECTOR_SOCRADAR_ID=changeme-uuid
SOCRADAR_API_KEY=
SOCRADAR_FEED_LISTS={"feed_list_1":"ID_1"}

# OpenSearch
OPENSEARCH_ADMIN_PASSWORD=changeme
