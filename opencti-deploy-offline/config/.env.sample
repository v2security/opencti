###############################################################################
# /etc/saids/opencti/.env — Config tập trung cho tất cả components
#
# Platform, Worker, Tools đều đọc từ file này.
# Dev/test: export OPENCTI_ENV_FILE=/workspace/tunv_opencti/.env
###############################################################################
OPENCTI_VERSION=6.9.22
COMPOSE_PROJECT_NAME=opencti-compose
XTM_COMPOSER_ID=changeme-uuid

# ── INFRASTRUCTURE ────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────
APP_PORT=8080
APP_BASE_URL=http://localhost:8080
APP_ADMIN_EMAIL=admin@v2secure.vn
APP_ADMIN_PASSWORD=changeme
APP_ADMIN_TOKEN=changeme-uuid
APP_HEALTH_ACCESS_KEY=changeme-uuid
APP_HTTPS_CERT_REJECT_UNAUTHORIZED=false

# ── Redis ────────────────────────────────────────────────────
REDIS_HOSTNAME=localhost
REDIS_PORT=6379
REDIS_PASSWORD=changeme

# ── Elasticsearch ────────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:8686
# ELASTICSEARCH_URL=http://elasticsearch:8686
ELASTICSEARCH_NUMBER_OF_REPLICAS=0
ELASTIC_MEMORY_SIZE=4G

# ── MinIO (S3) ───────────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=opencti
MINIO_SECRET_KEY=changeme
MINIO_BUCKET_NAME=opencti-bucket

# ── RabbitMQ ─────────────────────────────────────────────────
RABBITMQ_HOSTNAME=localhost
RABBITMQ_PORT=5672
RABBITMQ_PORT_MANAGEMENT=15672
RABBITMQ_MANAGEMENT_SSL=false
RABBITMQ_USERNAME=opencti
RABBITMQ_PASSWORD=changeme

# ── SMTP ─────────────────────────────────────────────────────
SMTP_HOSTNAME=localhost
SMTP_PORT=25

# ── AI / OpenAI-Compatible  ─────────────────────────────────
# Dùng type=openai cho cả OpenAI chính thức và backend OpenAI-compatible như vLLM.
AI_ENABLED=false
AI_TYPE=openai
AI_ENDPOINT=
AI_TOKEN=
AI_MODEL=
AI_MODEL_IMAGES=
AI_MAX_TOKENS=8192
AI_TIMEOUT=60000

# ── Chatbot / OpenAI-Compatible  ────────────────────────────
# Giữ cùng chuẩn cấu hình với AI để chatbot dùng chung OpenAI hoặc vLLM theo cùng một type.
CHATBOT_ENABLED=false
CHATBOT_TYPE=openai
CHATBOT_ENDPOINT=
CHATBOT_TOKEN=
CHATBOT_MODEL=
CHATBOT_MAX_TOKENS=4096

# ── Worker ───────────────────────────────────────────────────
WORKER_LOG_LEVEL=info
WORKER_TELEMETRY_ENABLED=false
WORKER_LISTEN_POOL_SIZE=5
OPENCTI_EXECUTION_POOL_SIZE=2
OPENCTI_REALTIME_EXECUTION_POOL_SIZE=3

# ── TOOLS ────────────────────────────────────────────────────

# ── MySQL (tools) ────────────────────────────────────────────
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=changeme
MYSQL_DATABASE=ids

# ── Maltrail Sync ────────────────────────────────────────────
# TOOL_DATA_DIR=/opt/tools/data
TOOL_DATA_DIR=/workspace/tunv_opencti/tools/data

# ── VirusTotal (hashlist sync - tool: es2mysql) ──────────────
VIRUSTOTAL_API_KEY=